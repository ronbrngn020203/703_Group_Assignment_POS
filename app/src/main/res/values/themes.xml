<?xml version="1.0" encoding="utf-8"?>
<resources xmlns:tools="http://schemas.android.com/tools">

    <style name="Theme.AISCafeteria" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="colorPrimary">@color/ais_red</item>
        <item name="colorPrimaryVariant">@color/ais_red_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/ais_red_light</item>
        <item name="colorOnSecondary">@color/white</item>
        <item name="android:windowBackground">@color/bg_light</item>
        <item name="android:statusBarColor">@color/status_bar</item>
        <item name="android:navigationBarColor">@color/white</item>
    </style>

    <style name="Theme.AISCafeteria.Splash" parent="Theme.AISCafeteria">
        <item name="android:windowFullscreen">true</item>
        <item name="android:windowBackground">@color/ais_red</item>
        <item name="android:statusBarColor">@color/ais_red</item>
    </style>

    <!-- Base AIS style -->
    <style name="AIS"></style>

    <!-- Card style -->
    <style name="AIS.Card" parent="Widget.MaterialComponents.CardView">
        <item name="cardCornerRadius">16dp</item>
        <item name="cardElevation">4dp</item>
        <item name="cardBackgroundColor">@color/card_white</item>
    </style>

    <!-- Button styles -->
    <style name="AIS.Button.Red" parent="Widget.MaterialComponents.Button">
        <item name="backgroundTint">@color/ais_red</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textSize">15sp</item>
    </style>

    <style name="AIS.Button.Outline" parent="Widget.MaterialComponents.Button.OutlinedButton">
        <item name="strokeColor">@color/ais_red</item>
        <item name="cornerRadius">12dp</item>
        <item name="android:textColor">@color/ais_red</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Text styles -->
    <style name="AIS.Text">
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="AIS.Text.Title">
        <item name="android:textSize">22sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="AIS.Text.SectionHeader">
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary</item>
    </style>

    <style name="AIS.Text.Body">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary</item>
    </style>

    <style name="AIS.Text.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_hint</item>
    </style>

</resources>