<?xml version="1.0" encoding="utf-8"?>
<!--
    activity_edit_menu_item.xml
    Layout for EditMenuItemActivity — Edit/update a menu item via HTTP PUT.
    Matches the existing AIS Cafeteria red/white design style.
-->
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="#F5F5F5">

    <!-- ── Toolbar ──────────────────────────────────────────── -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="56dp"
        android:background="#C0392B"
        android:gravity="center_vertical"
        android:orientation="horizontal"
        android:paddingStart="8dp"
        android:paddingEnd="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="40dp"
            android:layout_height="40dp"
            android:padding="8dp"
            android:src="@drawable/ic_back"
            android:tint="@android:color/white"
            android:contentDescription="Back" />

        <TextView
            android:id="@+id/tvEditTitle"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Edit Menu Item"
            android:textColor="@android:color/white"
            android:textSize="18sp"
            android:textStyle="bold"
            android:layout_marginStart="8dp" />

    </LinearLayout>

    <!-- ── Progress Bar ─────────────────────────────────────── -->
    <ProgressBar
        android:id="@+id/progressBar"
        style="?android:attr/progressBarStyleHorizontal"
        android:layout_width="match_parent"
        android:layout_height="4dp"
        android:indeterminate="true"
        android:visibility="gone"
        android:progressTint="#C0392B" />

    <!-- ── Scrollable Form ──────────────────────────────────── -->
    <ScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="16dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Name -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Item Name *"
                android:textColor="#333333"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etEditName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:hint="e.g. Butter Chicken Rice"
                android:inputType="textCapWords"
                android:layout_marginBottom="16dp" />

            <!-- Description -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Description"
                android:textColor="#333333"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etEditDescription"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:hint="Brief description of the item"
                android:inputType="textMultiLine"
                android:minLines="2"
                android:gravity="top"
                android:layout_marginBottom="16dp" />

            <!-- Price -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Price (NZD) *"
                android:textColor="#333333"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etEditPrice"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:hint="e.g. 12.50"
                android:inputType="numberDecimal"
                android:layout_marginBottom="16dp" />

            <!-- Category -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Category"
                android:textColor="#333333"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etEditCategory"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:hint="Mains / Salads / Snacks / Drinks / Desserts"
                android:inputType="textCapWords"
                android:layout_marginBottom="16dp" />

            <!-- Emoji -->
            <TextView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Emoji"
                android:textColor="#333333"
                android:textStyle="bold"
                android:textSize="13sp"
                android:layout_marginBottom="4dp" />

            <EditText
                android:id="@+id/etEditEmoji"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:background="@drawable/bg_input"
                android:padding="12dp"
                android:hint="e.g. 🍛"
                android:inputType="text"
                android:layout_marginBottom="24dp" />

            <!-- Save Button -->
            <Button
                android:id="@+id/btnSave"
                android:layout_width="match_parent"
                android:layout_height="52dp"
                android:background="@drawable/bg_btn_red_rounded"
                android:text="Save Changes"
                android:textColor="@android:color/white"
                android:textSize="16sp"
                android:textStyle="bold" />

        </LinearLayout>
    </ScrollView>

</LinearLayout>