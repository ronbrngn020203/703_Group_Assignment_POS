<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <application
        android:name=".CafeteriaApplication"
        android:allowBackup="true"
        android:icon="@mipmap/ic_launcher"
        android:label="@string/app_name"
        android:roundIcon="@mipmap/ic_launcher_round"
        android:supportsRtl="true"
        android:usesCleartextTraffic="true"
        android:theme="@style/Theme.AISCafeteria">

        <!-- Splash Screen -->
        <activity
            android:name=".activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AISCafeteria.Splash">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Activity -->
        <activity
            android:name=".activities.LoginActivity"
            android:exported="false" />

        <!-- Main / Dashboard Activity -->
        <activity
            android:name=".activities.MainActivity"
            android:exported="false" />

        <!-- Menu Activity -->
        <activity
            android:name=".activities.MenuActivity"
            android:exported="false" />

        <activity android:name=".activities.FindUsActivity" />

        <!-- Cart Activity -->
        <activity
            android:name=".activities.CartActivity"
            android:exported="false" />

        <!-- Payment Activity -->
        <activity
            android:name=".activities.PaymentActivity"
            android:exported="false" />

        <!-- Receipt Activity -->
        <activity
            android:name=".activities.ReceiptActivity"
            android:exported="false" />

        <!-- Order History Activity -->
        <activity
            android:name=".activities.OrderHistoryActivity"
            android:exported="false" />

        <!-- Gallery Activity -->
        <activity
            android:name=".activities.GalleryActivity"
            android:exported="false" />

        <!-- Contact/About Activity -->
        <activity
            android:name=".activities.ContactActivity"
            android:exported="false" />

        <activity
            android:name=".activities.NewsFeedActivity"
            android:exported="false" />

        <!-- Google Maps API Key -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyDss-QkynmkqqCKH7pz3D6g8Py_7OLVuU0" />

        <!-- Edit Menu Item Activity-->
        <activity
            android:name=".activities.EditMenuItemActivity"
            android:exported="false" />

    </application>

</manifest>
