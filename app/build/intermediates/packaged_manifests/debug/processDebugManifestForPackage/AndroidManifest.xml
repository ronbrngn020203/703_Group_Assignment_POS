<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android"
    package="com.ais.cafeteria.pos"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="26"
        android:targetSdkVersion="34" />

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CALL_PHONE" />
    <uses-permission android:name="android.permission.SEND_SMS" />
    <uses-permission android:name="android.permission.ACCESS_FINE_LOCATION" />
    <uses-permission android:name="android.permission.ACCESS_COARSE_LOCATION" />

    <!-- CALL_PHONE / SEND_SMS imply telephony; mark optional so tablets & Wi‑Fi devices can install -->
    <uses-feature
        android:name="android.hardware.telephony"
        android:required="false" />

    <!-- Include required permissions for Google Maps API to run. -->
    <uses-permission android:name="android.permission.ACCESS_NETWORK_STATE" />

    <uses-feature
        android:glEsVersion="0x00020000"
        android:required="true" />

    <queries>

        <!-- Needs to be explicitly declared on Android R+ -->
        <package android:name="com.google.android.apps.maps" />
    </queries>

    <permission
        android:name="com.ais.cafeteria.pos.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION"
        android:protectionLevel="signature" />

    <uses-permission android:name="com.ais.cafeteria.pos.DYNAMIC_RECEIVER_NOT_EXPORTED_PERMISSION" />

    <application
        android:name="com.ais.cafeteria.pos.CafeteriaApplication"
        android:allowBackup="true"
        android:appComponentFactory="androidx.core.app.CoreComponentFactory"
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:icon="@drawable/manna_logo"
        android:label="@string/app_name"
        android:roundIcon="@drawable/manna_logo"
        android:supportsRtl="true"
        android:testOnly="true"
        android:theme="@style/Theme.AISCafeteria"
        android:usesCleartextTraffic="true" >

        <!-- Splash Screen -->
        <activity
            android:name="com.ais.cafeteria.pos.activities.SplashActivity"
            android:exported="true"
            android:theme="@style/Theme.AISCafeteria.Splash" >
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />

                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>

        <!-- Login Activity -->
        <activity
            android:name="com.ais.cafeteria.pos.activities.LoginActivity"
            android:exported="false" />

        <!-- Main / Dashboard Activity -->
        <activity
            android:name="com.ais.cafeteria.pos.activities.MainActivity"
            android:exported="false" />

        <!-- Menu Activity -->
        <activity
            android:name="com.ais.cafeteria.pos.activities.MenuActivity"
            android:exported="false" />
        <activity android:name="com.ais.cafeteria.pos.activities.FindUsActivity" />

        <!-- Cart Activity -->
        <activity
            android:name="com.ais.cafeteria.pos.activities.CartActivity"
            android:exported="false" />

        <!-- Payment Activity -->
        <activity
            android:name="com.ais.cafeteria.pos.activities.PaymentActivity"
            android:exported="false" />

        <!-- Receipt Activity -->
        <activity
            android:name="com.ais.cafeteria.pos.activities.ReceiptActivity"
            android:exported="false" />

        <!-- Order History Activity -->
        <activity
            android:name="com.ais.cafeteria.pos.activities.OrderHistoryActivity"
            android:exported="false" />

        <!-- Gallery Activity -->
        <activity
            android:name="com.ais.cafeteria.pos.activities.GalleryActivity"
            android:exported="false" />

        <!-- Contact/About Activity -->
        <activity
            android:name="com.ais.cafeteria.pos.activities.ContactActivity"
            android:exported="false" />
        <activity
            android:name="com.ais.cafeteria.pos.activities.NewsFeedActivity"
            android:exported="false" />

        <!-- Google Maps API Key -->
        <meta-data
            android:name="com.google.android.geo.API_KEY"
            android:value="AIzaSyDss-QkynmkqqCKH7pz3D6g8Py_7OLVuU0" />

        <!-- Edit Menu Item Activity -->
        <activity
            android:name="com.ais.cafeteria.pos.activities.EditMenuItemActivity"
            android:exported="false" />

        <!-- Needs to be explicitly declared on P+ -->
        <uses-library
            android:name="org.apache.http.legacy"
            android:required="false" />

        <provider
            android:name="androidx.startup.InitializationProvider"
            android:authorities="com.ais.cafeteria.pos.androidx-startup"
            android:exported="false" >
            <meta-data
                android:name="androidx.emoji2.text.EmojiCompatInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.lifecycle.ProcessLifecycleInitializer"
                android:value="androidx.startup" />
            <meta-data
                android:name="androidx.profileinstaller.ProfileInstallerInitializer"
                android:value="androidx.startup" />
        </provider>

        <service
            android:name="com.google.firebase.components.ComponentDiscoveryService"
            android:directBootAware="true"
            android:exported="false" >
            <meta-data
                android:name="com.google.firebase.components:com.google.firebase.database.FirebaseDatabaseKtxRegistrar"
                android:value="com.google.firebase.components.ComponentRegistrar" />
            <meta-data
                android:name="com.google.firebase.components:com.google.firebase.database.DatabaseRegistrar"
                android:value="com.google.firebase.components.ComponentRegistrar" />
            <meta-data
                android:name="com.google.firebase.components:com.google.firebase.ktx.FirebaseCommonLegacyRegistrar"
                android:value="com.google.firebase.components.ComponentRegistrar" />
            <meta-data
                android:name="com.google.firebase.components:com.google.firebase.FirebaseCommonKtxRegistrar"
                android:value="com.google.firebase.components.ComponentRegistrar" />
        </service>

        <activity
            android:name="com.google.android.gms.common.api.GoogleApiActivity"
            android:exported="false"
            android:theme="@android:style/Theme.Translucent.NoTitleBar" />

        <provider
            android:name="com.google.firebase.provider.FirebaseInitProvider"
            android:authorities="com.ais.cafeteria.pos.firebaseinitprovider"
            android:directBootAware="true"
            android:exported="false"
            android:initOrder="100" />

        <meta-data
            android:name="com.google.android.gms.version"
            android:value="@integer/google_play_services_version" />

        <receiver
            android:name="androidx.profileinstaller.ProfileInstallReceiver"
            android:directBootAware="false"
            android:enabled="true"
            android:exported="true"
            android:permission="android.permission.DUMP" >
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.INSTALL_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SKIP_FILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.SAVE_PROFILE" />
            </intent-filter>
            <intent-filter>
                <action android:name="androidx.profileinstaller.action.BENCHMARK_OPERATION" />
            </intent-filter>
        </receiver>
    </application>

</manifest>