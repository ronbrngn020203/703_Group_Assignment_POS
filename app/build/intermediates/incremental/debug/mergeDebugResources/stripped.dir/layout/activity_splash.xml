<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/bg_red_gradient">

    <!-- Decorative circle top-right -->
    <View
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:background="#22FFFFFF"
        android:layout_marginTop="-60dp"
        android:layout_marginEnd="-60dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:id="@+id/circle_top" />

    <!-- Decorative circle bottom-left -->
    <View
        android:layout_width="160dp"
        android:layout_height="160dp"
        android:background="#15FFFFFF"
        android:layout_marginBottom="-50dp"
        android:layout_marginStart="-50dp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        android:id="@+id/circle_bottom" />

    <!-- Logo Container -->
    <LinearLayout
        android:id="@+id/logoContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toTopOf="@id/taglineText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp">

        <ImageView
            android:id="@+id/ivLogo"
            android:layout_width="120dp"
            android:layout_height="120dp"
            android:src="@drawable/ic_ais_logo_splash"
            android:contentDescription="AIS Logo" />

        <TextView
            android:id="@+id/tvAisName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Auckland Institute\nof Studies"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:gravity="center"
            android:layout_marginTop="12dp"
            android:letterSpacing="0.05" />

    </LinearLayout>

    <!-- Divider line -->
    <View
        android:id="@+id/dividerLine"
        android:layout_width="60dp"
        android:layout_height="2dp"
        android:background="#66FFFFFF"
        app:layout_constraintBottom_toTopOf="@id/appTitleText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="16dp" />

    <!-- App Title -->
    <TextView
        android:id="@+id/appTitleText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Cafeteria POS"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:textStyle="bold"
        android:letterSpacing="0.03"
        app:layout_constraintBottom_toTopOf="@id/taglineText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="8dp" />

    <!-- Tagline -->
    <TextView
        android:id="@+id/taglineText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Point of Sale System"
        android:textColor="#CCFFFFFF"
        android:textSize="14sp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent" />

    <!-- Loading dots -->
    <LinearLayout
        android:id="@+id/dotsContainer"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center"
        app:layout_constraintTop_toBottomOf="@id/taglineText"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginTop="40dp">

        <View android:id="@+id/dot1" android:layout_width="10dp" android:layout_height="10dp"
            android:background="#FFFFFFFF"
            android:layout_marginEnd="6dp" />
        <View android:id="@+id/dot2" android:layout_width="10dp" android:layout_height="10dp"
            android:background="#66FFFFFF"
            android:layout_marginEnd="6dp" />
        <View android:id="@+id/dot3" android:layout_width="10dp" android:layout_height="10dp"
            android:background="#33FFFFFF" />
    </LinearLayout>

    <!-- Version -->
    <TextView
        android:id="@+id/versionText"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/app_version"
        android:textColor="#66FFFFFF"
        android:textSize="11sp"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        android:layout_marginBottom="24dp" />

</androidx.constraintlayout.widget.ConstraintLayout>
