<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/bg_light">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:background="@drawable/bg_red_gradient"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:padding="16dp">

        <ImageView
            android:id="@+id/btnBack"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:src="@drawable/ic_back"
            android:tint="@color/white"
            android:background="@drawable/bg_card_translucent"
            android:padding="6dp"
            android:contentDescription="Back" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Your Cart"
            android:textColor="@color/white"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginStart="12dp" />

    </LinearLayout>

    <!-- Cart items RecyclerView -->
    <androidx.recyclerview.widget.RecyclerView
        android:id="@+id/rvCartItems"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:padding="12dp"
        android:clipToPadding="false"
        android:scrollbars="none" />

    <!-- Empty state -->
    <LinearLayout
        android:id="@+id/emptyState"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:orientation="vertical"
        android:gravity="center"
        android:visibility="gone">
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="🛒"
            android:textSize="60sp" />
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Your cart is empty"
            android:textColor="@color/text_secondary"
            android:textSize="16sp"
            android:textStyle="bold"
            android:layout_marginTop="12dp" />
        <Button
            android:id="@+id/btnBrowseMenu"
            android:layout_width="wrap_content"
            android:layout_height="44dp"
            android:text="Browse Menu"
            android:textColor="@color/white"
            android:background="@drawable/bg_btn_red_rounded"
            android:layout_marginTop="16dp"
            android:paddingStart="24dp"
            android:paddingEnd="24dp" />
    </LinearLayout>

    <!-- Order Note + Summary + Checkout -->
    <LinearLayout
        android:id="@+id/checkoutSection"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:background="@color/white"
        android:paddingTop="12dp"
        android:elevation="8dp">

        <!-- Note -->
        <EditText
            android:id="@+id/etOrderNote"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:background="@drawable/bg_input"
            android:hint="📝 Any special requests…"
            android:padding="12dp"
            android:textSize="13sp"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp" />

        <!-- Summary lines -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="4dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Subtotal"
                android:textColor="@color/text_secondary" android:textSize="13sp" />
            <TextView android:id="@+id/tvSubtotal" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="$0.00"
                android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="13sp" />
        </LinearLayout>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="8dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="GST (15%)"
                android:textColor="@color/text_secondary" android:textSize="13sp" />
            <TextView android:id="@+id/tvGst" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="$0.00"
                android:textColor="@color/text_primary" android:textStyle="bold" android:textSize="13sp" />
        </LinearLayout>

        <View android:layout_width="match_parent" android:layout_height="1dp"
            android:background="@color/divider"
            android:layout_marginStart="16dp" android:layout_marginEnd="16dp" android:layout_marginBottom="8dp" />

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:paddingStart="16dp"
            android:paddingEnd="16dp"
            android:layout_marginBottom="12dp">
            <TextView android:layout_width="0dp" android:layout_height="wrap_content"
                android:layout_weight="1" android:text="Total"
                android:textColor="@color/text_primary" android:textSize="16sp" android:textStyle="bold" />
            <TextView android:id="@+id/tvTotal" android:layout_width="wrap_content"
                android:layout_height="wrap_content" android:text="$0.00"
                android:textColor="@color/ais_red" android:textStyle="bold" android:textSize="16sp" />
        </LinearLayout>

        <Button
            android:id="@+id/btnCheckout"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="Proceed to Payment →"
            android:textColor="@color/white"
            android:textSize="15sp"
            android:textStyle="bold"
            android:background="@drawable/bg_btn_red_rounded"
            android:layout_marginStart="12dp"
            android:layout_marginEnd="12dp"
            android:layout_marginBottom="12dp" />

    </LinearLayout>

</LinearLayout>
